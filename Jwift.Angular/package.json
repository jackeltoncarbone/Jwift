{
  "name": "jwift-angular",
  "version": "0.1.0",
  "description": "Angular bindings for Jwift — Swift-style UI templates built on Jaui",
  "private": true,
  "type": "module",
  "module": "./dist/jwift-angular/fesm2022/jwift-angular.mjs",
  "typings": "./dist/jwift-angular/types/jwift-angular.d.ts",
  "exports": {
    "./package.json": { "default": "./package.json" },
    ".": {
      "types": "./dist/jwift-angular/types/jwift-angular.d.ts",
      "default": "./dist/jwift-angular/fesm2022/jwift-angular.mjs"
    }
  },
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "peerDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/core": "^21.2.0",
    "jaui": "*",
    "jaui-angular": "*"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "jsdom": "^28.0.0",
    "jaui": "*",
    "jaui-angular": "*",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "rxjs": "~7.8.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "sideEffects": false
}
